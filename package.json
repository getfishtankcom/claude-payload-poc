{
  "name": "fras-canada-poc",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "FRAS Canada PoC — Next.js 15 + Payload CMS 3.x + Tailwind CSS v4",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "generate:types": "payload generate:types",
    "generate:importmap": "payload generate:importmap",
    "migrate": "payload migrate",
    "migrate:create": "payload migrate:create",
    "migrate:status": "payload migrate:status",
    "migrate:fresh": "payload migrate:fresh",
    "migrate:reset": "payload migrate:reset",
    "migrate:refresh": "payload migrate:refresh",
    "db:push": "payload migrate --push",
    "crawl": "node scripts/crawl-sitemap.mjs",
    "classify": "node scripts/classify-pages.mjs",
    "inspect": "node scripts/inspect-pages.mjs",
    "report": "node scripts/generate-reports.mjs",
    "inventory": "bash scripts/run-inventory.sh",
    "registry": "node scripts/build-url-registry.mjs",
    "self-test": "node scripts/self-test.mjs",
    "seed": "cross-env NODE_OPTIONS='--no-warnings' tsx --tsconfig tsconfig.json src/seed/index.ts",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build -o storybook-static"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.9",
    "@heroicons/react": "^2.2.0",
    "@meilisearch/instant-meilisearch": "^0.30.0",
    "@payloadcms/db-postgres": "^3.77.0",
    "@payloadcms/next": "^3.77.0",
    "@payloadcms/richtext-lexical": "^3.77.0",
    "@payloadcms/ui": "^3.77.0",
    "dotenv": "^16.4.7",
    "graphql": "^16.10.0",
    "mammoth": "^1.11.0",
    "meilisearch": "^0.55.0",
    "next": "15.4.11",
    "next-intl": "^4.8.3",
    "payload": "^3.77.0",
    "pdf-parse": "^2.4.5",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-instantsearch": "^7.26.1",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.4",
    "@storybook/addon-a11y": "^8.6.17",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-interactions": "^8.6.14",
    "@storybook/blocks": "^8.6.14",
    "@storybook/react-vite": "^8.6.17",
    "@tailwindcss/postcss": "^4.1.4",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^22.15.3",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "cross-env": "^7.0.3",
    "eslint": "^9.26.0",
    "eslint-config-next": "15.4.11",
    "playwright": "^1.52.0",
    "postcss": "^8.5.3",
    "prettier": "^3.5.3",
    "storybook": "^8.6.17",
    "tailwindcss": "^4.1.4",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "vite": "^6.4.1"
  }
}
