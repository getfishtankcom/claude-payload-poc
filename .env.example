# =============================================================================
# FRAS Canada — Environment Variables
# Copy to .env and fill in values before running `npm run dev`
# NEVER commit .env to version control.
# =============================================================================

# ── Database (PostgreSQL) ──────────────────────────────────────────────────
# Connection string for Payload CMS + Drizzle ORM
DATABASE_URI=postgresql://postgres:postgres@localhost:5432/fras

# ── Payload CMS ───────────────────────────────────────────────────────────
# Secret used to sign JWT tokens and encrypt session data
# Generate with: openssl rand -hex 32
PAYLOAD_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32

# Base URL for the application (used by Payload for links, CORS)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# ── Meilisearch ─────────────────────────────────────────────────────────
# Self-hosted Docker instance (see docker-compose.yml)
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=fras-dev-master-key
NEXT_PUBLIC_MEILISEARCH_HOST=http://localhost:7700
NEXT_PUBLIC_MEILISEARCH_SEARCH_KEY=

# ── Aptify (Member Auth) ──────────────────────────────────────────────────
# Direct DB API — NOT OAuth/SAML. Simple member True/False check.
APTIFY_API_URL=
APTIFY_API_KEY=

# ── JWT / Session ─────────────────────────────────────────────────────────
# Custom JWT session management (HTTP-only cookie)
# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32

# ── HubSpot (Newsletter / CRM) ───────────────────────────────────────────
HUBSPOT_PORTAL_ID=
HUBSPOT_FORM_ID=
# Only needed if using HubSpot API for newsletter preferences management
# HUBSPOT_API_KEY=

# ── Google ReCaptcha v3 ───────────────────────────────────────────────────
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# ── Google Analytics (GA4) ────────────────────────────────────────────────
NEXT_PUBLIC_GA_ID=

# ── OneTrust (Cookie Consent) ─────────────────────────────────────────────
NEXT_PUBLIC_ONETRUST_DOMAIN_SCRIPT=

# ── Email / SMTP (Member Form Submissions) ────────────────────────────────
# 3 member-only forms (Document Comment, Event Registration, Volunteer)
# all send emails with attachments — no data storage
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@frascanada.ca

# ── S3 / Object Storage (Optional) ───────────────────────────────────────
# Only needed if using S3-compatible storage instead of local disk for media
# S3_BUCKET=
# S3_REGION=ca-central-1
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_ENDPOINT=
