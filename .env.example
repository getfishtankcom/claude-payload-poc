# =============================================================================
# FRAS Canada — Environment Variables
# Copy to .env and fill in values before running `npm run dev`
# NEVER commit .env to version control.
# =============================================================================

# ── Database (PostgreSQL) ──────────────────────────────────────────────────
# Connection string for Payload CMS + Drizzle ORM
DATABASE_URI=postgresql://postgres:postgres@localhost:5432/fras

# ── Payload CMS ───────────────────────────────────────────────────────────
# Secret used to sign JWT tokens and encrypt session data
# Generate with: openssl rand -hex 32
PAYLOAD_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32

# Base URL for the application (used by Payload for links, CORS)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Secret used by /api/preview to authenticate live-preview iframe requests
# from the page builder. Generate with `openssl rand -hex 32`.
PREVIEW_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32

# Build timestamp shown on /cms; set by your deploy pipeline.
NEXT_PUBLIC_BUILD_TIME=

# ── Meilisearch ─────────────────────────────────────────────────────────
# Self-hosted Docker instance (see docker-compose.yml)
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=fras-dev-master-key
NEXT_PUBLIC_MEILISEARCH_HOST=http://localhost:7700
# Default Search API Key Meilisearch generates from MEILI_MASTER_KEY=fras-dev-master-key.
# Deterministic per master key — same key on every fresh container. Search-only
# (no write access), safe to expose to the browser. For prod, use a unique
# master key + a generated search-only key.
NEXT_PUBLIC_MEILISEARCH_SEARCH_KEY=21064765ec8c9473984a45ea602d1635d425c9dbce2690839bc281c2c7e5aff1

# ── Clerk (Auth) ──────────────────────────────────────────────────────────
# Clerk handles frontend auth (login, signup, session management).
# In dev, keyless mode works without these — just run the app.
# For production, get keys from https://dashboard.clerk.com/
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# ── Anthropic API (AI Translation Workflow — PRD §13) ───────────────────
# Used by src/lib/translation/translator.ts and the batch-translate script.
# Get a key from https://console.anthropic.com/settings/keys
# Required for /api/admin/translate and the FR translation batch run.
ANTHROPIC_API_KEY=

# Cost safeguards — defaults are deliberately conservative for the
# validation phase. Raise once you trust the pipeline.
#
# Hard cumulative-USD ceiling. Calls past this throw before the API call.
# Default: $10 (set deliberately low for the demo run; real corpus is ~$1-3).
TRANSLATION_COST_CEILING_USD=10
# Output token cap per call. Sonnet 4.6 charges $15/M output. Default 4096.
TRANSLATION_MAX_TOKENS_PER_REQUEST=4096
# Pre-flight input cap (uses free messages.countTokens to refuse oversized
# inputs before billing). Default 20K — most docs are well under 5K.
TRANSLATION_MAX_INPUT_TOKENS=20000
# Min ms between calls (rate-limit for the batch script). Default 500.
TRANSLATION_MIN_DELAY_MS=500
# Absolute per-call worst-case USD cap (independent of cumulative).
# Even with budget left, refuse any single call whose worst case
# exceeds this. Default $1.00.
TRANSLATION_PER_CALL_USD_CAP=1.00
# Log a warning when cumulative spend crosses this % of ceiling
# (does NOT block — fires once per Translator instance). Default 80.
TRANSLATION_BUDGET_WARN_PCT=80
# Override the model. Default 'claude-sonnet-4-6'.
# Cheap dev option: 'claude-haiku-4-5' ($1/M input, $5/M output — 3× cheaper).
# TRANSLATION_MODEL=claude-sonnet-4-6
# Dry-run mode — skip the SDK call entirely, return synthetic FR
# (prefixes EN string with "[FR-DRY] "). Lets you smoke-test the
# broadcast/batch flow with $0 spend. Default false.
# TRANSLATION_DRY_RUN=false
# Override the cost log path. Default <repo>/.ai-reports/translation-cost.log
# TRANSLATION_COST_LOG_PATH=
# Skip seeding cumulativeUsd from the existing cost log. Default false.
# Each Translator instance reads the log and starts at the lifetime
# total — so the cost ceiling enforces ACROSS route calls + batch runs,
# not just within one instance. Set to "true" to reset (after rotating
# the log file or intentionally starting fresh).
# TRANSLATION_SKIP_LIFETIME_BUDGET=false
# Hard kill switch. Set to "true" to immediately disable translation.
# TRANSLATION_DISABLED=false

# ── HubSpot (Newsletter / CRM) ───────────────────────────────────────────
HUBSPOT_PORTAL_ID=
HUBSPOT_FORM_ID=
# Only needed if using HubSpot API for newsletter preferences management
# HUBSPOT_API_KEY=

# ── Google ReCaptcha v3 ───────────────────────────────────────────────────
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# ── Google Analytics (GA4) ────────────────────────────────────────────────
NEXT_PUBLIC_GA_ID=

# ── OneTrust (Cookie Consent) ─────────────────────────────────────────────
NEXT_PUBLIC_ONETRUST_DOMAIN_SCRIPT=

# ── Email / SMTP (Member Form Submissions) ────────────────────────────────
# 3 member-only forms (Document Comment, Event Registration, Volunteer)
# all send emails with attachments — no data storage
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@frascanada.ca

# ── S3 / Object Storage (Optional) ───────────────────────────────────────
# Only needed if using S3-compatible storage instead of local disk for media
# S3_BUCKET=
# S3_REGION=ca-central-1
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_ENDPOINT=
